{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist", "**/*.test.ts", "test/**/*"]
}
